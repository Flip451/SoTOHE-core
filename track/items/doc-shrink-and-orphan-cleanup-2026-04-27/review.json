          "verdict": "findings_remain",
          "findings": [
            {
              "message": "AC-02 accepts `README.md` at ≤90 lines, but CN-01 in the same spec says Tier 1 files, explicitly including `README.md`, must be ≤80 lines. That means an 81-90 line README would satisfy the acceptance criterion while violating the plan's stated Tier 1 constraint.",
              "severity": "P1",
              "file": "track/items/doc-shrink-and-orphan-cleanup-2026-04-27/spec.json",
              "line": 272,
              "category": "contradiction"
            },
            {
              "message": "AC-04 makes `LOCAL_DEVELOPMENT.md` pass at ≤120 lines even though IN-04 and the D3 target cited by the spec require shrinking it to about 90 lines. This leaves the shrink target non-binding, so a materially under-shrunk file could satisfy the plan's acceptance gate.",
              "severity": "P1",
              "file": "track/items/doc-shrink-and-orphan-cleanup-2026-04-27/spec.json",
              "line": 300,
              "category": "contradiction"
            }
