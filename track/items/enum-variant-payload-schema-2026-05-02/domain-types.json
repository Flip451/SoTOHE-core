  "type_definitions": [
    {
      "name": "EnumVariantDeclaration",
      "description": "Structured declaration for a single enum variant, holding the variant name and an ordered list of payload type strings. A unit variant is represented with payload_types: []. Payload type strings follow the L1 last-segment convention (no ::).",
      "approved": true,
      "kind": "value_object",
      "expected_members": [
        {
          "kind": "field",
          "name": "name",
          "ty": "String"
        },
        {
          "kind": "field",
          "name": "payload_types",
          "ty": "Vec<String>"
        }
      ],
      "expected_methods": [],
