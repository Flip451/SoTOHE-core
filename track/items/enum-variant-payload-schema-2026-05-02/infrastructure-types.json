    {
      "name": "build_type_graph",
      "description": "Builds a TypeGraph from a SchemaExport. The SchemaExport is produced by schema_export.rs::extract_enum_variants() (extended in T001/IN-07) which already carries payload_types per variant; build_type_graph propagates those payload_types into the resulting TypeGraph nodes without re-parsing rustdoc JSON itself.",
      "approved": true,
      "action": "modify",
      "kind": "free_function",
      "module_path": "infrastructure::code_profile_builder",
      "expected_params": [
        {
          "name": "schema",
          "ty": "SchemaExport"
        },
        {
          "name": "typestate_names",
          "ty": "HashSet<String>"
        }
      ],
      "expected_returns": [
        "TypeGraph"
      ],
      "expected_is_async": false,
      "spec_refs": [
