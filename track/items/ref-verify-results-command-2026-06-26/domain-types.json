      "docs": "Validated newtype for a spec.json element identifier (e.g. `IN-01`, `AC-03`). Pattern: two or more ASCII uppercase letters, a hyphen, one or more digits. Defined in plan_ref::spec_ref; referenced here because SpecElementRef carries it as the `element_id` field.",
      "spec_refs": [],
      "informal_grounds": []
