          "ty": "&BTreeMap<LayerId, TypeCatalogueDocument>"
        },
        {
          "name": "layer_order",
          "ty": "&[LayerId]"
        },
        {
          "name": "opts",
          "ty": "&ContractMapRenderOptions"
        }
      ],
      "expected_returns": [
        "ContractMapContent"
      ],
      "expected_is_async": false,
