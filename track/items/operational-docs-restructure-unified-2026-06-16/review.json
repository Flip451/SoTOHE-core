          "findings": [
            {
              "message": "Deleting `DEVELOPER_AI_WORKFLOW.md` leaves the doc-pattern verifier still hard-coded to that file. `REQUIRED_LINES` and `CONVENTIONS_REQUIRED_LINES` still require `cargo make verify-track-metadata`, `cargo make verify-tech-stack`, `cargo make verify-latest-track`, `/track:revert`, and the conventions-reference line from `DEVELOPER_AI_WORKFLOW.md`, so `cargo make ci` will now fail once `verify_architecture_docs` runs.",
              "severity": "P1",
              "file": "/home/flip451/individual/t-rust/templates/SoTOHE-core/libs/infrastructure/src/verify/doc_patterns.rs",
              "line": 103,
              "category": "dead-reference"
            }
          ],
