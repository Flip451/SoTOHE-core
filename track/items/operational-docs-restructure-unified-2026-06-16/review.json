        {
          "type": "fast",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "P1: [README.md](/home/flip451/individual/t-rust/templates/SoTOHE-core/README.md#L90) and [README.md](/home/flip451/individual/t-rust/templates/SoTOHE-core/README.md#L96) misstate the canonical `/track:adr2pr` flow. The README says the command runs `/track:plan` and then implements/reviews/commits/creates the PR, but the actual orchestrator explicitly says not to invoke `/track:plan`, requires an initial ADR review+commit, and ends at `/track:pr-review` with no merge ([.claude/commands/track/adr2pr.md](/home/flip451/individual/t-rust/templates/SoTOHE-core/.claude/commands/track/adr2pr.md#L19), [.claude/commands/track/adr2pr.md](/home/flip451/individual/t-rust/templates/SoTOHE-core/.claude/commands/track/adr2pr.md#L39)). A newcomer following the README will execute the wrong sequence and miss required steps.",
              "severity": "P1",
              "file": "/home/flip451/individual/t-rust/templates/SoTOHE-core/README.md",
              "line": 90,
              "category": "correctness"
            }
          ],
          "hash": "rvw1:sha256:45bb0b0351d47ddf222b7d4e66c3f7563c0108094f5b9c17ac8af17777f26a85",
          "at": "2026-06-17T05:05:26Z"
