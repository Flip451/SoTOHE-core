  "traits": {
    "LintConfigLoader": {
      "action": "add",
      "role": { "SecondaryPort": {} },
      "methods": [
        {
          "name": "load",
          "receiver": "&self",
          "params": [],
          "returns": "Result<LintConfig, LintConfigLoaderError>",
          "is_async": false,
          "generics": [],
          "has_default_impl": false,
          "where_predicates": [],
          "docs": "Loads and parses a LintConfig from the path baked into the adapter at construction time. Returns LintConfigLoaderError::MissingFile if the file does not exist (fail-closed — no silent fallback). Returns ParseError on JSON/structure failures. Returns SchemaVersionMismatch on version field mismatch. The path is not passed at call time — the adapter implementation (FsLintConfigLoader) receives the fully-resolved path in its constructor (new()), allowing CLI composition to decide whether to use the workspace default path or a --rules-file override path before constructing the adapter."
        }
      ],
      "supertrait_bounds": ["Send", "Sync"],
      "module_path": "catalogue_lint_workflow",
      "docs": "Secondary port for loading lint configuration from a file. Abstracts the external I/O of reading .harness/catalogue-lint/config.json or a --rules-file path. Implementations live in the infrastructure layer (FsLintConfigLoader). The path is resolved at adapter construction time (not at load() call time), so CLI composition decides which path to use (CLI override or workspace default) before wiring the adapter. Send + Sync bounds allow the port to be held by the generic interactor across thread boundaries.",
      "spec_refs": [
        {
          "file": "track/items/tddd-pattern-semantics-extension-2026-06-13/spec.json",
