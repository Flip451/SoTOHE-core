        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "The new body walk only visits `Stmt::Item` entries that are direct children of the function/method/default-method block. Rust items can also be declared inside nested blocks or control-flow bodies, e.g. `fn f() { if cond { #[doc(hidden)] struct X; } }`; those appear under expression blocks and are skipped here, so the new doc-hidden gate still has a production bypass. The scanner needs to recurse through statement expressions/blocks, or use `syn::visit`, while preserving the existing `#[cfg(test)]` pruning.",
              "severity": "P1",
              "file": "libs/infrastructure/src/verify/syn_scan.rs",
              "line": 485,
              "category": "scanner false negative"
            }
