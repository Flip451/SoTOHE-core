          "hash": "rvw1:sha256:c961303cbb9b58eb98c722a95d06bdbc39a729b146d046bde5e18c3fc42e0815",
          "at": "2026-06-26T17:08:52Z"
        },
        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "The transitive test-module check only treats a parent file as test-only when that parent was itself reached through a file-backed `#[cfg(test)] mod` chain. It does not consider a module file's own inner `#![cfg(test)]` attribute, even though `scan_single_file` skips such files directly. As a result, `lib.rs` with `mod tests;`, `tests.rs` with `#![cfg(test)]\nmod helpers;`, and `tests/helpers.rs` with `#[doc(hidden)]` will classify `helpers.rs` as production-referenced and report a false violation, despite the whole parent module being test-only. This breaks the required `#[cfg(test)]` pruning for file-backed descendants.",
              "severity": "P1",
              "file": "libs/infrastructure/src/verify/syn_scan.rs",
              "line": 289,
              "category": "cfg-test exclusion"
            }
          ],
          "hash": "rvw1:sha256:c961303cbb9b58eb98c722a95d06bdbc39a729b146d046bde5e18c3fc42e0815",
          "at": "2026-06-26T17:13:01Z"
