          "verdict": "findings_remain",
          "findings": [
            {
              "message": "Routing ancestor-directory probes through `classify_sibling_probe` drops the recursive `mod` walk that `classify_file_module_references` provides. That means legitimate test-only references from an ancestor sibling into a nested target path, e.g. `src/foo.rs` -> `src/foo/fixtures/helpers.rs` via `mod fixtures { mod helpers; }`, will no longer exclude the target file and `#[doc(hidden)]` violations in those files will be reported incorrectly.",
              "severity": "P1",
              "file": "/home/flip451/individual/t-rust/templates/SoTOHE-core-003/libs/infrastructure/src/verify/syn_scan.rs",
              "line": 437,
