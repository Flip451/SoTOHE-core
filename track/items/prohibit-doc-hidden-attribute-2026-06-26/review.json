        {
          "type": "fast",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "`candidate.parent() != path.parent()` prevents recursion into same-directory module files, so transitive test-only inheritance still fails for common chains like `lib.rs -> a.rs -> b.rs` (or any same-directory `mod` chain). In that case `b.rs` is still treated as production-reachable and `#[doc(hidden)]` there will be flagged even though it is only reachable through `#[cfg(test)]`.",
              "severity": "P1",
              "file": "libs/infrastructure/src/verify/syn_scan.rs",
              "line": 285,
              "category": "correctness"
            }
          ],
          "hash": "rvw1:sha256:8dfd6b9af9b16442f2970b9144eb9c6ee310652dcee721c62cfdeecf73158258",
          "at": "2026-06-26T16:59:40Z"
