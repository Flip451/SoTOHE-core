          "verdict": "findings_remain",
          "findings": [
            {
              "message": "`RunReviewFixInteractor::run` returns the injected closure's `RunReviewFixOutput` unchanged, so the service can successfully surface an arbitrary status or a mismatched exit code such as `status = \"completed\"` with `exit_code = 2`. The usecase contract limits results to `completed`/`blocked_cross_scope`/`failed` with fixed exit-code mapping, so the boundary should validate the returned DTO and convert invalid output to an error before returning.",
              "severity": "P1",
              "file": "libs/usecase/src/review_v2/run_review_fix.rs",
