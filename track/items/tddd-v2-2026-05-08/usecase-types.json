      "action": "add",
      "role": "ErrorType",
      "kind": {
        "kind": "enum",
        "variants": [
          { "name": "InvalidTrackId", "payload": { "kind": "struct", "fields": [{ "name": "reason", "ty": "String" }] } },
          { "name": "LayerBindingsLoad", "payload": { "kind": "struct", "fields": [{ "name": "reason", "ty": "String" }] } },
          { "name": "CatalogueLoad", "payload": { "kind": "struct", "fields": [{ "name": "layer_id", "ty": "String" }, { "name": "reason", "ty": "String" }] } },
          { "name": "BaselineLoad", "payload": { "kind": "struct", "fields": [{ "name": "layer_id", "ty": "String" }, { "name": "reason", "ty": "String" }] } },
          { "name": "ExtendedCrateConversion", "payload": { "kind": "struct", "fields": [{ "name": "layer_id", "ty": "String" }, { "name": "reason", "ty": "String" }] } },
          { "name": "SchemaExport", "payload": { "kind": "struct", "fields": [{ "name": "layer_id", "ty": "String" }, { "name": "reason", "ty": "String" }] } },
          { "name": "Evaluation", "payload": { "kind": "struct", "fields": [{ "name": "layer_id", "ty": "String" }, { "name": "reason", "ty": "String" }] } },
          { "name": "SymlinkRejected", "payload": { "kind": "struct", "fields": [{ "name": "path", "ty": "String" }] } },
          { "name": "NoLayers" }
        ]
      },
      "trait_impls": [
        { "trait_name": "Display", "origin_crate": "core" },
        { "trait_name": "Error", "origin_crate": "core" }
      ],
      "docs": "Error type for CatalogueImplSignalsService::run. Variants: InvalidTrackId (track id format invalid), LayerBindingsLoad (loading TDDD layer bindings from architecture-rules.json failed; covers both file-read/parse failure and requested layer not found or not tddd.enabled), CatalogueLoad (A-side catalogue document read/decode failure), BaselineLoad (B-side baseline rustdoc load failure), ExtendedCrateConversion (A-side CatalogueDocument → ExtendedCrate conversion failure), SchemaExport (C-side live capture failure), Evaluation (signal evaluator failure), SymlinkRejected (path traversal or symlink guard rejection from the security validation in the interactor), NoLayers (no TDDD-enabled layers found or resolved). [source: ADR 2026-05-11-2330 D2]",
      "spec_refs": [
        { "file": "track/items/tddd-v2-2026-05-08/spec.json", "anchor": "IN-18", "hash": "25956e359d8c1c93d9ce4901902f3ae0108b25bcf0cda2597b20addad58a704a" }
      ],
      "informal_grounds": []
    },
