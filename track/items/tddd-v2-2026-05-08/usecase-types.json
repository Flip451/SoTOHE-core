    "CatalogueImplSignalsInteractor": {
      "action": "add",
      "role": "Interactor",
      "kind": {
        "kind": "plain_struct",
        "has_stripped_fields": true
      },
      "trait_impls": [{ "trait_name": "CatalogueImplSignalsService", "origin_crate": "usecase" }],
      "methods": [
        {
          "name": "new",
          "params": [
            { "name": "catalogue_loader", "ty": "Arc<dyn domain::tddd::catalogue_v2::CatalogueDocumentLoaderPort>" },
            { "name": "ext_crate_codec", "ty": "Arc<dyn domain::tddd::CatalogueToExtendedCratePort>" },
            { "name": "evaluator", "ty": "Arc<dyn domain::tddd::signal_evaluator::SignalEvaluatorPort>" },
