          "at": "2026-04-12T03:39:09Z"
        },
        {
          "type": "fast",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "The new `TreeEntryKind::Submodule` rejection path in `fetch_blob_safe` is not covered by any fixture test. Because this is a security-sensitive fail-closed branch, a regression in 160000 handling could ship without detection. Please add an integration test that commits a submodule and asserts `fetch_blob_safe` returns `BlobResult::CommandFailed` for it.",
              "severity": "P1",
              "file": "/home/flip451/individual/t-rust/templates/SoTOHE-core/libs/infrastructure/src/git_cli/show.rs",
              "line": 185,
              "category": "test coverage"
            }
          ],
          "hash": "rvw1:sha256:f6fbdaa20cd5e98936473be59b4fbc357266a5b2421f2e578c214fe63b1306ea",
          "at": "2026-04-12T04:31:44Z"
