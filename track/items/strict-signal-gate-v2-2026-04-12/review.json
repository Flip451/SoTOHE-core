          "hash": "rvw1:sha256:a9b8d527ba1869757296eef23a9c47f7745cf637241e98884190561e54e56f11",
          "at": "2026-04-12T04:37:08Z"
        },
        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "`fetch_blob_safe` validates `origin/<branch>` with `git ls-tree` and then does a second symbolic-ref lookup in `git_show_blob`. If a concurrent `git fetch` moves `origin/<branch>` between those calls, the mode check can approve commit A while `git show` returns bytes from commit B. That breaks the D4.3 fail-closed guarantee; a symlink blob in commit B can carry attacker-controlled JSON text and bypass the intended pre-read rejection. Resolve `origin/<branch>` to a commit once and use that object ID for both commands.",
              "severity": "P0",
              "file": "libs/infrastructure/src/git_cli/show.rs",
              "line": 185,
              "category": "security"
            }
          ],
          "hash": "rvw1:sha256:a9b8d527ba1869757296eef23a9c47f7745cf637241e98884190561e54e56f11",
          "at": "2026-04-12T04:40:05Z"
