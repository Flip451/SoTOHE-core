        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "`check_domain_types_signals()` is documented as a single gate where any Red signal, including undeclared reverse signals, must fail, but the new tests only exercise Red on a declared entry. There is no domain-level regression test for an undeclared reverse Red signal, so a future refactor that accidentally limits the Red check to declared entries would still pass this suite.",
              "severity": "P1",
              "file": "libs/domain/src/tddd/catalogue.rs",
              "line": 2276,
              "category": "testing"
            }
          ],
          "hash": "rvw1:sha256:4268f973c7790aaed3c8268612297ba2fce0797f27dc4492005f625f8ffe1302",
          "at": "2026-04-12T03:03:26Z"
        },
        {
