          "hash": "rvw1:sha256:4268f973c7790aaed3c8268612297ba2fce0797f27dc4492005f625f8ffe1302",
          "at": "2026-04-12T03:04:51Z"
        },
        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "The Yellow branch message omits the remediation hint required for this Stage 2 gate. It reports that the merge gate will block, but unlike the Stage 1 warning it never tells the caller how to turn Yellow into Blue, so the user-visible contract in the briefing/ADR is not met.",
              "severity": "P1",
              "file": "libs/domain/src/tddd/catalogue.rs",
              "line": 1055,
              "category": "requirements"
            },
            {
              "message": "The new tests never exercise a Red signal on an undeclared reverse entry. That special case is the key distinction in the ADR ('Red over all signals, Yellow over declared only'), so a regression that accidentally limits the Red gate to declared entries would still pass this suite.",
              "severity": "P1",
              "file": "libs/domain/src/tddd/catalogue.rs",
              "line": 2276,
              "category": "tests"
            }
          ],
          "hash": "rvw1:sha256:4268f973c7790aaed3c8268612297ba2fce0797f27dc4492005f625f8ffe1302",
