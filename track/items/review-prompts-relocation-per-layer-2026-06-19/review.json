          "verdict": "findings_remain",
          "findings": [
            {
              "message": "CN-01/ADR D5 require the clean-move migration commit to update all references, explicitly including docs, at the same time as loader paths, briefing_file values, harness-policy patterns, and tests. The implementation plan instead makes T002+T003 the atomic migration and then schedules the live-doc reference updates as T004 after that paired migration. That leaves an intermediate planned commit sequence that violates the stated clean-move constraint and contradicts the task coverage that maps CN-01 only to T002/T003 while IN-07/IN-08 are deferred to T004.",
              "severity": "P1",
              "file": "track/items/review-prompts-relocation-per-layer-2026-06-19/impl-plan.json",
