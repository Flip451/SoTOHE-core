          "at": "2026-06-02T01:42:59Z"
        },
        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "The build args use `${{ env.HOST_UID }}` / `${{ env.HOST_GID }}`, but these values are only created by the prior `GITHUB_ENV` write at runtime. GitHub evaluates expressions for action inputs before runner-generated environment values are available, so these expand empty rather than to the host UID/GID. That means Docker receives empty `CI_UID`/`CI_GID` values and the `chown -R ${CI_UID}:${CI_GID} ...` step can fail or avoid assigning ownership to the runtime user, breaking the CI image build or the baked dependency reuse this change is meant to enable. Pass these through step outputs or another mechanism available to expressions.",
              "severity": "P1",
              "file": ".github/workflows/ci.yml",
              "line": 61,
              "category": "ci"
            }
          ],
          "hash": "rvw1:sha256:87d30af18685c1d7796f322aa0b42f636ea44a8a59c8b40cf9edae9742203acb",
