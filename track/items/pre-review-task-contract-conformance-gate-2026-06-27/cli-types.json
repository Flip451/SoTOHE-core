      "methods": [],
      "module_path": "commands::task_contract",
      "docs": "Arguments for `sotp task-contract coverage`. track_id: active track identifier (opaque CLI string); when omitted, auto-resolved from the current git branch (track/<id>). items_dir: path to the track items directory; defaults to 'track/items'. Coverage checks all 6 canonical TDDD layers simultaneously (no per-layer flag; attribution completeness is a whole-catalogue invariant that cannot be checked per-layer in isolation).",
      "spec_refs": [
