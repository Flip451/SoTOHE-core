        {
          "type": "final",
          "verdict": "findings_remain",
          "findings": [
            {
              "message": "`WherePredicateDecl.lhs` is now skipped entirely by the primitive-occurrence rule. That avoids passing expressions like `&'a T` to the Bound scanner, but it also means a valid predicate such as `where Vec<String>: Clone` is no longer scanned at any position, so `ForbidPrimitiveInTypes` can silently miss the raw `String` in a TypeRef-bearing catalogue slot. This reintroduces the primitive-obsession hole the rule is supposed to close; preserve the no-Bound-parse-failure behavior while still scanning lhs as a type expression under an appropriate position/adapter path.",
              "severity": "P1",
              "file": "libs/domain/src/tddd/catalogue_linter_eval_primitives.rs",
              "line": 425,
              "category": "primitive obsession"
            }
