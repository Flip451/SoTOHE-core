          {
            "name": "AmbiguousIdentifier",
            "payload": {
              "kind": "struct",
              "fields": [
                { "name": "name", "ty": "String" }
              ]
            }
          }
        ]
      },
      "methods": [],
      "trait_impls": [
        { "trait_name": "Debug", "origin_crate": "core" },
        { "trait_name": "Display", "origin_crate": "core" },
        { "trait_name": "Error", "origin_crate": "core" }
      ],
      "module_path": "tddd",
      "docs": "Infrastructure-level error for CatalogueToExtendedCrateCodec. action:modify with trait_impls [Debug, Display, Error] declared so that B-side children (including the From<CatalogueToExtendedCrateCodecError> for NewTypeGraphCodecError orphan impl) are removed from S and replaced by A-codec content — workaround for evaluator bug: patch_impl_for_ids causes the external-for_ From impl to incorrectly pass for_is_external=false in S while C correctly filters it (for_is_external=true), generating spurious SMinusC_Reference Red.",
      "spec_refs": [],
      "informal_grounds": [
        {
          "kind": "user_directive",
          "summary": "action:modify required to remove B-seeded From<CatalogueToExtendedCrateCodecError> for NewTypeGraphCodecError impl from S. patch_impl_for_ids in Phase 1 child_items.rs replaces the impl for_.id with the parent type id (CatalogueToExtendedCrateCodecError), causing for_is_external=false in S while C correctly identifies NewTypeGraphCodecError as external (for_is_external=true via paths entry crate_id!=0). This produces SMinusC_Reference Red for the impl key. Declaring modify+remove_b_children eliminates the key from S and resolves the Red."
        }
      ]
    },
