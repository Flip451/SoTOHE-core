{
  "version": 1,
  "extra_dirs": [
    {
      "path": "project-docs/conventions",
      "label": "project-specific engineering rules"
    },
    {
      "path": "track",
      "label": "track workflow state and planning artifacts"
    },
    {
      "path": "track/items/<id>",
      "label": "active track directory"
    },
    {
      "path": "track/archive/<id>",
      "label": "archived track directory"
    }
  ],
  "layers": [
    {
      "crate": "domain",
      "path": "libs/domain",
      "may_depend_on": [],
      "deny_reason": "Domain dependencies are controlled by layer boundaries."
    },
    {
      "crate": "usecase",
      "path": "libs/usecase",
      "may_depend_on": [
        "domain"
      ],
      "deny_reason": "Usecase crate must only be consumed by the cli layer."
    },
    {
      "crate": "infrastructure",
      "path": "libs/infrastructure",
      "may_depend_on": [
        "domain"
      ],
      "deny_reason": "Infrastructure implementations must be wired only at composition root."
    },
    {
      "crate": "cli",
      "path": "apps/cli",
      "may_depend_on": [
        "domain",
        "infrastructure",
        "usecase"
      ],
      "deny_reason": ""
    }
  ]
}
