{
  "version": 1,
  "active_profile": "default",
  "providers": {
    "claude": {
      "label": "Claude Code",
      "supported_capabilities": [
        "orchestrator",
        "planner",
        "implementer",
        "reviewer",
        "debugger"
      ],
      "invoke_examples": {
        "default": "/track:status",
        "orchestrator": "/track:status",
        "planner": "/track:plan <feature>",
        "implementer": "/track:implement",
        "reviewer": "/track:review",
        "debugger": "Continue in the active Claude Code session with the full error context."
      }
    },
    "codex": {
      "label": "Codex CLI",
      "default_model": "gpt-5.4",
      "fast_model": "gpt-5.3-codex-spark",
      "supported_capabilities": [
        "planner",
        "researcher",
        "implementer",
        "reviewer",
        "debugger"
      ],
      "invoke_examples": {
        "default": "codex exec --model {model} --sandbox read-only --full-auto \"{task}\"",
        "planner": "codex exec --model {model} --sandbox read-only --full-auto \"{task}\"",
        "researcher": "codex exec --model {model} --sandbox read-only --full-auto \"Research this Rust topic: {task}\"",
        "implementer": "codex exec --model {model} --sandbox workspace-write --full-auto \"{task}\"",
        "reviewer": "cargo make track-local-review -- --model {model} --prompt \"{task}\"",
        "debugger": "codex exec --model {model} --sandbox read-only --full-auto \"{task}\""
      }
    },
    "gemini": {
      "label": "Gemini CLI",
      "supported_capabilities": [
        "researcher",
        "multimodal_reader"
      ],
      "invoke_examples": {
        "default": "gemini -p \"Research: {task}\"",
        "researcher": "gemini -p \"Research: {task}\"",
        "multimodal_reader": "gemini -p \"Extract from {path}: {task}\""
      }
    }
  },
  "profiles": {
    "default": {
      "orchestrator": "claude",
      "planner": "codex",
      "researcher": "gemini",
      "implementer": "claude",
      "reviewer": "codex",

      "debugger": "codex",
      "multimodal_reader": "gemini",
      "workflow_host_provider": "claude",
      "workflow_host_model": "claude-opus-4-6"
    },
    "claude-heavy": {
      "orchestrator": "claude",
      "planner": "claude",
      "researcher": "gemini",
      "implementer": "claude",
      "reviewer": "claude",

      "debugger": "codex",
      "multimodal_reader": "gemini",
      "workflow_host_provider": "claude",
      "workflow_host_model": "claude-opus-4-6"
    },
    "codex-heavy": {
      "orchestrator": "claude",
      "planner": "codex",
      "researcher": "codex",
      "implementer": "codex",
      "reviewer": "codex",

      "debugger": "codex",
      "multimodal_reader": "gemini",
      "workflow_host_provider": "codex",
      "workflow_host_model": "gpt-5.4"
    }
  }
}
