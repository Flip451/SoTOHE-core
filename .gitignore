# --- Rust ---
target/
target-*/
**/*.rs.bk

# Keep Cargo.lock for application projects.
# Uncomment the next line if this template is used for a library crate.
# Cargo.lock

# --- Tooling caches / outputs ---
.claude/logs/
.claude/scheduled_tasks.lock
.sotp-record-round.lock

# --- Environment / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Project-specific sensitive directories (see knowledge/conventions/security.md) ---
private/
config/secrets/

# --- Editor / OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# --- Stale lock directory from removed file-lock system (safe to delete locally) ---
.locks/

# --- Advisory lock files created by with_locked_document (fs4) ---
*.json.lock

# --- Runtime lock files (review cycle mutual exclusion) ---
.sotp-record-round.lock

# --- Legacy local cache ---
__pycache__/
*.pyc

# --- Auto mode ephemeral session state (not version-controlled) ---
**/auto-state.json

# --- Build artifacts ---
*.rlib
rust_out

# --- Built CLI binary (regenerated by cargo make bootstrap) ---
/bin/sotp

# --- Generated views (rendered from metadata.json, not version-controlled) ---
track/registry.md

# --- TDDD baseline snapshots (captured by `sotp track baseline-capture`, not version-controlled) ---
track/items/**/*-baseline.json

# --- TDDD rendered type-graph cluster dirs (generated by `sotp track type-graph`, not version-controlled) ---
# Legacy suffix-less path retained for backward compatibility (no new outputs land here);
# active cluster-mode outputs use the depth-suffixed pattern below.
track/items/**/*-graph/
# Depth-suffixed cluster-mode dirs introduced by ADR
# `2026-04-25-0530-type-designer-recon-options-defaults.md` D2
# (e.g. `domain-graph-d1/`, `domain-graph-d2/`).
track/items/**/*-graph-d*/

# --- Review v2: per-track commit hash (local diff base state, not version-controlled) ---
track/items/**/.commit_hash
track/items/**/.commit_hash.tmp

# --- Temp / local scratch ---
tmp/
.track-template-dev
repomix-output.txt
repomix-output.xml

# --- Local Claude Code settings override (not version-controlled) ---
.claude/settings.local.json

# --- Local cached external reference guides (not version-controlled) ---
.cache/external-guides/
.cache/cargo/
.cache/home/
.cache/pytest/
.cache/sccache/
